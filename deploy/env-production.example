APP_NAME="Chatbot Keperawatan"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://chatbot-keperawatan.damgocompany.com
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=GANTI_NAMA_DATABASE
DB_USERNAME=GANTI_USER_DATABASE
DB_PASSWORD=GANTI_PASSWORD_DATABASE

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=public

BROADCAST_CONNECTION=log
MAIL_MAILER=log

# TTS
TTS_DRIVER=php
TTS_CLIENT_ONLY=true

# Upload video edukasi (KB) — 122880 = 120 MB
VIDEO_MAX_UPLOAD_KB=122880

# Konsultasi online
CONSULTATION_WA_API=https://api.whatsapp.com/send
CONSULTATION_PRICE=25000
CONSULTATION_PRICE_PERAWAT=25000
CONSULTATION_PRICE_DOKTER_UMUM=50000
CONSULTATION_PRICE_DOKTER_SPESIALIS=75000
CONSULTATION_SESSION_HOURS=24
CONSULTATION_DANA_MERCHANT=Chatbot Keperawatan
CONSULTATION_DANA_PHONE=085645527751

# WhatsApp Notification
CONSULTATION_WA_NOTIFY_DRIVER=log
FONNTE_TOKEN=
WABLAS_TOKEN=
WABLAS_SECRET=
